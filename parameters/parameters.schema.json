{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SCGIS-Wales/entraid-app-registration/parameters.schema.json",
  "title": "Entra Enterprise App Registration Parameters (SCGIS Wales)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "appName",
    "displayName",
    "environment",
    "businessUnit",
    "changeTicket",
    "owner",
    "signInAudience",
    "tokenVersion",
    "platforms",
    "exposedApi",
    "requiredPermissions"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": "2.0"},
    "appName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9\\-]{2,59}$"
    },
    "displayName": {"type": "string", "minLength": 3, "maxLength": 120},
    "environment": {"enum": ["dev", "qual", "prod"]},
    "businessUnit": {"type": "string", "minLength": 2},
    "changeTicket": {"type": "string", "pattern": "^(CHG|REQ|INC)[0-9]{6,10}$"},
    "owner": {
      "type": "object",
      "required": ["groupObjectId", "primaryContact"],
      "properties": {
        "groupObjectId": {"type": "string", "format": "uuid"},
        "primaryContact": {"type": "string", "format": "email"}
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "signInAudience": {
      "enum": ["AzureADMyOrg", "AzureADMultipleOrgs", "AzureADandPersonalMicrosoftAccount"]
    },
    "tokenVersion": {"enum": [1, 2]},
    "platforms": {
      "type": "object",
      "required": ["spa", "web", "publicClient"],
      "properties": {
        "spa": {
          "type": "object",
          "required": ["enabled", "redirectUris"],
          "properties": {
            "enabled": {"type": "boolean"},
            "redirectUris": {
              "type": "array",
              "items": {"type": "string", "format": "uri"},
              "uniqueItems": true,
              "maxItems": 256
            }
          }
        },
        "web": {
          "type": "object",
          "required": ["enabled", "redirectUris"],
          "properties": {
            "enabled": {"type": "boolean"},
            "redirectUris": {"type": "array", "items": {"type": "string", "format": "uri"}, "uniqueItems": true},
            "implicitGrant": {
              "type": "object",
              "properties": {
                "accessToken": {"type": "boolean"},
                "idToken": {"type": "boolean"}
              }
            }
          }
        },
        "publicClient": {
          "type": "object",
          "required": ["enabled", "redirectUris"],
          "properties": {
            "enabled": {"type": "boolean"},
            "redirectUris": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
          }
        }
      }
    },
    "exposedApi": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "identifierUri": {"type": "string"},
        "scopes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "type", "adminConsentDisplayName", "adminConsentDescription"],
            "properties": {
              "value": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9\\.]{1,239}$"},
              "type": {"enum": ["User", "Admin"]},
              "adminConsentDisplayName": {"type": "string"},
              "adminConsentDescription": {"type": "string"},
              "userConsentDisplayName": {"type": ["string", "null"]},
              "userConsentDescription": {"type": ["string", "null"]}
            }
          }
        },
        "appRoles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "displayName", "description", "allowedMemberTypes"],
            "properties": {
              "value": {"type": "string"},
              "displayName": {"type": "string"},
              "description": {"type": "string"},
              "allowedMemberTypes": {
                "type": "array",
                "items": {"enum": ["User", "Application"]},
                "minItems": 1
              }
            }
          }
        }
      }
    },
    "requiredPermissions": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "required": ["resource"],
            "additionalProperties": false,
            "properties": {
              "resource": {"const": "MicrosoftGraph"},
              "delegated": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "application": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          },
          {
            "type": "object",
            "required": ["resource"],
            "additionalProperties": false,
            "properties": {
              "resource": {"$ref": "#/$defs/uuid"},
              "delegated": {"type": "array", "items": {"$ref": "#/$defs/uuid"}},
              "application": {"type": "array", "items": {"$ref": "#/$defs/uuid"}}
            }
          }
        ]
      }
    },
    "preAuthorizedApplications": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["appId", "delegatedScopeIds"],
        "additionalProperties": false,
        "properties": {
          "appId": {"$ref": "#/$defs/uuid"},
          "delegatedScopeIds": {
            "type": "array",
            "items": {"$ref": "#/$defs/uuid"},
            "minItems": 1
          }
        }
      }
    },
    "obo": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "knownClientApplicationIds": {
          "type": "array",
          "items": {"type": "string", "format": "uuid"},
          "maxItems": 20
        }
      }
    },
    "federatedCredentials": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["name", "issuer", "subject", "audience"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9\\-]{3,120}$"},
          "issuer": {"type": "string", "format": "uri"},
          "subject": {"type": "string", "minLength": 1, "maxLength": 600},
          "audience": {"type": "string"},
          "description": {"type": "string"}
        }
      }
    },
    "optionalClaims": {
      "type": "object",
      "properties": {
        "idToken": {"type": "array", "items": {"$ref": "#/$defs/optionalClaim"}},
        "accessToken": {"type": "array", "items": {"$ref": "#/$defs/optionalClaim"}},
        "saml2Token": {"type": "array", "items": {"$ref": "#/$defs/optionalClaim"}}
      }
    },
    "groupMembershipClaims": {
      "enum": ["None", "SecurityGroup", "ApplicationGroup", "DirectoryRole", "All"]
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "optionalClaim": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "essential": {"type": "boolean"},
        "additionalProperties": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
